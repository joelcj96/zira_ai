PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/zira-ai
JWT_SECRET=replace_with_secure_secret
OPENAI_API_KEY=
FRONTEND_URL=http://localhost:5173
# In production you can provide multiple origins separated by commas, for example:
# FRONTEND_URL=https://zira-ai.vercel.app,https://zira-ai-git-main-joelcj96.vercel.app,https://zira-ai-joelcj96.vercel.app
FREE_PLAN_DAILY_PROPOSALS=5

# Real external job feed:
# Pulls from 6 live job boards: Remotive, Arbeitnow, The Muse, RemoteOK, Jobicy, and Himalayas.
# No API keys required for any of these providers.
DISABLE_REAL_JOB_FEED=false
REAL_JOB_SYNC_INTERVAL_MINUTES=360
REAL_JOB_FETCH_TIMEOUT_MS=10000
REAL_JOB_MAX_RESULTS=600
REAL_JOB_ARBEITNOW_MAX_PAGES=3
REAL_JOB_THE_MUSE_MAX_PAGES=3
REAL_JOB_JOBICY_MAX_JOBS=50
REAL_JOB_HIMALAYAS_MAX_JOBS=100
REAL_JOB_ALLOW_MOCK_FALLBACK=false

# Billing provider abstraction:
# - stripe: use Stripe checkout/subscriptions
# - manual: redirect users to MANUAL_BILLING_CONTACT_URL (recommended where Stripe is unsupported)
BILLING_PROVIDER=stripe
MANUAL_BILLING_CONTACT_URL=
SUPPORT_EMAIL=nkashamailunga96@gmail.com

# External apply connector:
# When enabled, manual apply actions can call your external apply webhook to submit on integrated platforms.
# Set EXTERNAL_APPLY_WEBHOOK_URL to your integration endpoint that executes real submissions.
EXTERNAL_APPLY_ENABLED=false
EXTERNAL_APPLY_WEBHOOK_URL=
EXTERNAL_APPLY_TIMEOUT_MS=15000
GREENHOUSE_DIRECT_APPLY_ENABLED=true
GREENHOUSE_DEFAULT_PHONE=
LEVER_DIRECT_APPLY_ENABLED=true
ASHBY_DIRECT_APPLY_ENABLED=true
SMARTRECRUITERS_DIRECT_APPLY_ENABLED=true

STRIPE_SECRET_KEY=
STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=card

# Stripe pricing:
# Preferred: set STRIPE_PRO_PRICE_ID to your recurring Stripe Price ID (price_...)
# Optional fallback (if no price id): set STRIPE_PRO_PRICE_USD_CENTS / STRIPE_PRO_YEARLY_PRICE_USD_CENTS
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_PRO_PRICE_USD_CENTS=1900
STRIPE_PRO_YEARLY_PRICE_USD_CENTS=19000
STRIPE_WEBHOOK_SECRET=
ADMIN_EMAIL=joel@gmail.com
ADMIN_PASSWORD=joelantita1996
